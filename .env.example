VITE_API_BASE_URL=/api
# Local dev: Vite proxies /api (and /uploads) to this target to avoid CORS.
VITE_API_PROXY_TARGET=http://localhost:4000
# Tip (production): if your frontend is served over HTTPS, your API must also be HTTPS (or be proxied on the same origin like /api).
# Optional: set to true to force http even if you provide an https URL (useful for local/dev only).
VITE_FORCE_HTTP=false